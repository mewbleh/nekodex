{
  "name": "nekodex",
  "version": "1.0.1",
  "description": "Lightweight TypeScript agent CLI inspired by Codex.",
  "type": "module",
  "bin": {
    "nekodex": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "repository": "https://github.com/mewbleh/nekodex",
  "author": "mewbleh <mewblehh@gmail.com>",
  "license": "Apache-2.0",
  "private": false,
  "files": [
    "dist",
    "README.md",
    "AGENT.md",
    "SKILL.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "blessed": "^0.1.81",
    "commander": "^13.0.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/blessed": "^0.1.27",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
